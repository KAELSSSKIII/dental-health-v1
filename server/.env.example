# Railway usually injects DATABASE_URL when you attach a Postgres service.
DATABASE_URL=postgresql://user:password@host:5432/database

# Or set individual PostgreSQL variables.
DB_HOST=your-db-host
DB_PORT=5432
DB_NAME=dental_clinic
DB_USER=dental_clinic_user
DB_PASSWORD=your_db_password
DB_SSL=false

JWT_SECRET=a_very_long_random_secret_key_here

PORT=3001

CLIENT_URL=https://your-vercel-frontend.vercel.app
