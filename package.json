{
    "name": "dental-health-v1",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "concurrently \"npm run server\" \"npm run client\" --names \"API,UI\" --prefix-colors \"cyan,magenta\"",
        "server": "cd server && npm run dev",
        "client": "cd client && npm run dev",
        "install:all": "npm install && cd server && npm install && cd ../client && npm install",
        "db:setup": "cd server && npm run db:setup"
    },
    "devDependencies": {
        "concurrently": "^9.1.2"
    }
}